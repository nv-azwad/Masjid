{
  "expo": {
    "name": "Gausul Azam Jameh Masjid",
    "slug": "gausul-azam-mosjid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "masjid",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0f1210"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f1210"
      },
      "package": "com.trinovent.gausulazam",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.trinovent.gausulazam",
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sensors",
      "expo-notifications",
      "expo-location",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9b01943-395a-43e3-9266-0f68a31bd6d5"
      }
    },
    "owner": "nv-azwad"
  }
}
